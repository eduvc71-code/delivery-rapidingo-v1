{
  "name": "delivery-rapidingo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "homepage": "https://eduvc71-code.github.io/delivery-rapidingo-v1",
  "scripts": {
    "dev": "vite",
    "prebuild": "npm run assets:restaurants:check",
    "build": "tsc && vite build",
    "prebuild:android": "npm run assets:restaurants:check",
    "build:android": "powershell -ExecutionPolicy Bypass -File scripts/build_android_apks.ps1",
    "prebuild:android:release": "npm run assets:restaurants:check",
    "build:android:release": "powershell -ExecutionPolicy Bypass -File scripts/build_android_apks.ps1 -BuildType Release",
    "build:pwas": "npm run build && node scripts/package_pwas.mjs && npm run pwas:check",
    "preview:pwas": "npm run build:pwas && vite preview --host 127.0.0.1",
    "deploy:cloudflare:cliente": "npm run build:pwas && npx wrangler pages deploy dist/cliente --project-name rapidingo-cliente",
    "deploy:cloudflare:delivery": "npm run build:pwas && npx wrangler pages deploy dist/delivery --project-name rapidingo-delivery",
    "deploy:cloudflare:restaurante": "npm run build:pwas && npx wrangler pages deploy dist/restaurante --project-name rapidingo-restaurante",
    "deploy:cloudflare:admin": "npm run build:pwas && npx wrangler pages deploy dist/admin --project-name rapidingo-admin",
    "preview": "vite preview",
    "loadtest": "node scripts/loadtest/rapidingo-loadtest.js",
    "loadtest:small": "node scripts/loadtest/rapidingo-loadtest.js --scenario=small --mode=both",
    "loadtest:large": "node scripts/loadtest/rapidingo-loadtest.js --scenario=large --mode=both",
    "capacity:sim": "node scripts/loadtest/rapidingo-capacity-sim.js",
    "realtime:smoke": "node scripts/loadtest/rapidingo-realtime-smoke.js",
    "assets:restaurants:check": "node scripts/validate_restaurant_assets.js",
    "pwas:check": "node scripts/validate_pwa_packages.js",
    "predeploy": "npm run build:pwas",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@google/genai": "^0.12.0",
    "@supabase/supabase-js": "^2.43.0",
    "@tailwindcss/vite": "^4.0.0",
    "lucide-react": "^0.344.0",
    "pocketbase": "^0.26.9",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.12.2",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.3.0",
    "gh-pages": "^6.1.1",
    "typescript": "^5.4.2",
    "vite": "^6.0.0"
  }
}
